rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // True when the caller is signed in via Firebase Auth.
    function isAuth() {
      return request.auth != null;
    }

    // True when the Firebase Auth uid matches the document id (owner check).
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Read the caller's own Users/{uid} doc and return their role.
    // Used to gate admin-only paths without a second round-trip from the client.
    function callerRole() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role;
    }

    // True when the caller is an Admin or MainAdmin.
    function isAdmin() {
      return isAuth() && callerRole() in ['Admin', 'MainAdmin'];
    }

    // True when the caller is a MainAdmin only.
    function isMainAdmin() {
      return isAuth() && callerRole() == 'MainAdmin';
    }


    // ── Anonymous / authenticated session backup ──────────────────────────────
    //
    // Document key = Firebase Auth uid.
    // Only the owning user may read, write, or delete their own session doc.
    match /_pnrc_sessions/{uid} {
      allow read, write, delete:
        if isOwner(uid);
    }


    // ── User profiles ─────────────────────────────────────────────────────────
    //
    // Document key = Firebase Auth uid (set by FirebaseService._writeUserDocument).
    // Fields: email, role, createdAt, lastLoginAt, provider, mfaEnabled, …
    //
    // Access matrix:
    //   READ   — own document, OR any Admin/MainAdmin (needed by RbacService
    //            .getUserRole and .userRoleStream which read Users/{firebaseUid}).
    //   CREATE — owner only; role must be absent or exactly "Tourist".
    //   UPDATE — owner may update own doc but cannot change their role.
    //            Admin/MainAdmin may update any doc (role promotion on accept).
    //   DELETE — never from the client.
    match /Users/{uid} {

      allow read:
        if isOwner(uid) || isAdmin();

      allow create:
        if isOwner(uid)
        && (!('role' in request.resource.data)
            || request.resource.data.role == 'Tourist');

      allow update:
        if (isOwner(uid)
            && (!('role' in request.resource.data)
                || request.resource.data.role == resource.data.role))
        || isAdmin();

      allow delete: if false;
    }


    // ── Admin Role Requests ───────────────────────────────────────────────────
    //
    // Collection: AdminRequests
    // Document fields written by RbacService.submitAdminRequest:
    //   firebaseUid      — Firebase Auth uid of the requester  ← identity anchor
    //   userId           — custom API id (stored for backend cross-reference)
    //   userEmail        — string
    //   facilityName     — string
    //   servicesOffered  — string[]
    //   agreedToTerms    — bool
    //   status           — 'pending' | 'accepted' | 'denied'
    //   createdAt        — timestamp
    //   (on update) grantedRole, denialReason, respondedAt, respondedBy, …
    //
    // Access matrix:
    //   READ   — the requester (firebaseUid == caller uid), OR MainAdmin.
    //   CREATE — authenticated user; firebaseUid must equal caller uid;
    //            status must start as 'pending'.
    //   UPDATE — MainAdmin only (approve / deny).
    //   DELETE — never from the client.
    match /AdminRequests/{requestId} {

      allow read:
        if isAuth()
        && (resource.data.firebaseUid == request.auth.uid || isMainAdmin());

      allow create:
        if isAuth()
        && request.resource.data.firebaseUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update:
        if isMainAdmin();

      allow delete: if false;
    }


    // ── Blog posts mirror ─────────────────────────────────────────────────────
    //
    // Any authenticated user may read.
    // Only Admin / MainAdmin may write.
    match /blog_posts/{slug} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

  }
}